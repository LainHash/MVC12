@model MVC12.DTOs.Products.Update.UpdateProductDTO

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<!-- Product Edit Section -->
<div class="container-fluid product-form-section py-5">
    <div class="container">
        <!-- Header -->
        <div class="row mb-5">
            <div class="col-12">
                <div class="d-flex align-items-center mb-4">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle me-3">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <div>
                        <h1 class="display-5 mb-2">
                            <i class="fas fa-edit text-primary me-3"></i>Chỉnh sửa sản phẩm
                        </h1>
                        <p class="text-secondary">Cập nhật thông tin sản phẩm</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Form Card -->
            <div class="col-lg-8 mx-auto">
                <div class="form-card">
                    <form asp-action="Edit" method="post" class="product-form" novalidate>
                        <!-- Validation Summary -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Lỗi xảy ra!</strong> Vui lòng kiểm tra lại các trường nhập liệu.
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        <!-- Basic Info Section -->
                        <div class="form-section mb-5">
                            <h5 class="form-section-title mb-4">
                                <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                            </h5>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="ProductName" class="form-label fw-bold">
                                            Tên sản phẩm <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="ProductName"
                                               class="form-control form-control-lg"
                                               placeholder="Nhập tên sản phẩm..."
                                               required />
                                        <span asp-validation-for="ProductName" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="ImageUrl" class="form-label fw-bold">
                                            URL hình ảnh <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="ImageUrl"
                                               class="form-control form-control-lg"
                                               placeholder="https://..."
                                               type="url" />
                                        <span asp-validation-for="ImageUrl" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-group">
                                        <label asp-for="Description" class="form-label fw-bold">
                                            Mô tả sản phẩm
                                        </label>
                                        <textarea asp-for="Description"
                                                  class="form-control"
                                                  rows="4"
                                                  placeholder="Nhập mô tả chi tiết sản phẩm..."></textarea>
                                        <span asp-validation-for="Description" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Category & Supplier Section -->
                        <div class="form-section mb-5">
                            <h5 class="form-section-title mb-4">
                                <i class="fas fa-folder-open me-2"></i>Phân loại
                            </h5>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="CategoryId" class="form-label fw-bold">
                                            Loại sản phẩm <span class="text-danger">*</span>
                                        </label>
                                        <select asp-for="CategoryId"
                                                class="form-select form-select-lg"
                                                asp-items="ViewBag.CategoryId"
                                                required>
                                            <option value="">-- Chọn loại --</option>
                                        </select>
                                        <span asp-validation-for="CategoryId" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="SupplierId" class="form-label fw-bold">
                                            Nhà cung cấp <span class="text-danger">*</span>
                                        </label>
                                        <select asp-for="SupplierId"
                                                class="form-select form-select-lg"
                                                asp-items="ViewBag.SupplierId"
                                                required>
                                            <option value="">-- Chọn NCC --</option>
                                        </select>
                                        <span asp-validation-for="SupplierId" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pricing & Stock Section -->
                        <div class="form-section mb-5">
                            <h5 class="form-section-title mb-4">
                                <i class="fas fa-tag me-2"></i>Giá và kho hàng
                            </h5>

                            <div class="row g-4">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="UnitPrice" class="form-label fw-bold">
                                            Giá bán (đ) <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="UnitPrice"
                                               class="form-control form-control-lg"
                                               type="number"
                                               min="0"
                                               required />
                                        <span asp-validation-for="UnitPrice" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="UnitsInStock" class="form-label fw-bold">
                                            Số lượng kho <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="UnitsInStock"
                                               class="form-control form-control-lg"
                                               type="number"
                                               min="0"
                                               required />
                                        <span asp-validation-for="UnitsInStock" class="text-danger small d-block mt-2"></span>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="Discontinued" class="form-label fw-bold">
                                            Ngừng kinh doanh
                                        </label>
                                        <div class="form-check form-switch mt-2">
                                            <input asp-for="Discontinued"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   id="discontinuedCheck"
                                                   style="width: 50px; height: 25px; cursor: pointer;" />
                                            <label class="form-check-label" for="discontinuedCheck">
                                                <span class="discontinue-text ms-2">Còn bán</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Specifications Section -->
                        <div class="form-section mb-5">
                            <h5 class="form-section-title mb-4">
                                <i class="fas fa-cogs me-2"></i>Thông số kỹ thuật
                            </h5>
                            <div class="specifications-container">
                                @await Component.InvokeAsync("UpdateProductSpec", new {dto = Model, categoryId = Model.CategoryId})
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="form-actions mt-6 pt-4 border-top">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 rounded-pill">
                                        <i class="fas fa-times me-2"></i>Hủy
                                    </a>
                                </div>
                                <div class="col-md-6">
                                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill form-submit-btn">
                                        <i class="fas fa-save me-2"></i>Lưu thay đổi
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
