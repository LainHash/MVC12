@model IEnumerable<MVC12.ViewModels.Products.ProductVM>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<!-- Product Listing Section -->
<div class="container-fluid products-section py-5">
    <div class="container">
        <!-- Header -->
        <div class="row mb-5">
            <div class="col-12">
                <div class="text-center mb-4">
                    <h1 class="display-4">
                        <span class="text-primary">Danh sách</span> Sản phẩm
                    </h1>
                    <p class="text-secondary fs-5">Khám phá bộ sưu tập laptop và linh kiện máy tính chất lượng cao</p>
                </div>

                <!-- Action Button -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="filter-badge">
                        <span class="badge bg-primary me-2">
                            <i class="fas fa-list"></i> @Model.Count() sản phẩm
                        </span>
                    </div>
                    <a asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus me-2"></i>Thêm sản phẩm mới
                    </a>
                </div>
            </div>
        </div>

        <!-- Filter Form -->
        <form asp-action="Index" method="get" class="filter-form mb-5 product-filter-form">
            <div class="row g-3 mb-4">
                <div class="col-lg-4 col-md-6">
                    <label class="form-label fw-bold">
                        <i class="fas fa-search me-2"></i>Tìm kiếm sản phẩm
                    </label>
                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control form-control-lg search-input"
                           placeholder="Nhập tên sản phẩm..."
                           aria-label="Tìm kiếm" />
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold">
                        <i class="fas fa-folder-open me-2"></i>Loại sản phẩm
                    </label>
                    <select class="form-select form-select-lg category-filter"
                            name="categoryId"
                            asp-items="ViewBag.CategoryId"
                            aria-label="Chọn loại">
                        <option value="0">-- Tất cả loại --</option>
                    </select>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold">
                        <i class="fas fa-building me-2"></i>Nhà cung cấp
                    </label>
                    <select class="form-select form-select-lg supplier-filter"
                            name="supplierId"
                            asp-items="ViewBag.SupplierId"
                            aria-label="Chọn NCC">
                        <option value="0">-- Tất cả NCC --</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-bold">
                        <i class="fas fa-sort me-2"></i>Sắp xếp
                    </label>
                    <select class="form-select form-select-lg sort-filter"
                            name="orderBy"
                            asp-items="ViewBag.OrderTypes"
                            aria-label="Chọn sắp xếp">
                        <option value="">Mới nhất</option>
                    </select>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary btn-lg w-100 filter-submit-btn">
                        <i class="fas fa-filter me-2"></i>Áp dụng bộ lọc
                    </button>
                </div>
            </div>
        </form>
        @await Html.PartialAsync("_ProductGrid", Model)
    </div>
</div>

